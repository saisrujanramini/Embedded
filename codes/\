#include<stdio.h>
int main(){
	int j,i,size,temp;
	printf("enter the size of the array:");
	scanf("%d",&size);
	int arr[size];
	for (i=0;i<size;i++){
		printf("enetr the %d element of the array",i);
		scanf("%d",&arr[i]);
	}
	for (i=0,j=size;i<j;i++,j--){
		temp=arr[j];
		arr[j]=arr[i];
		arr[i]=temp;
	}
	for(i=0;i<size;i++){
		printf("%d",arr[i]);
	}
}

